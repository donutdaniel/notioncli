{
  "cases": [
    {
      "name": "current-user",
      "cli": ["user", "me"],
      "mcp": {
        "tool": "notion-get-users",
        "arguments": {
          "user_id": "self"
        }
      }
    },
    {
      "name": "list-users-page1",
      "cli": ["user", "list", "--page-size", "1"],
      "mcp": {
        "tool": "notion-get-users",
        "arguments": {
          "page_size": 1
        }
      }
    },
    {
      "name": "fetch-page",
      "cli": ["page", "get", "$PAGE_ID"],
      "mcp": {
        "tool": "notion-fetch",
        "arguments": {
          "id": "$PAGE_ID"
        }
      }
    },
    {
      "name": "search-page",
      "cli": ["search", "$SEARCH_QUERY", "--type", "page", "--limit", "1"],
      "mcp": {
        "tool": "notion-search",
        "arguments": {
          "query": "$SEARCH_QUERY",
          "query_type": "internal",
          "content_search_mode": "workspace_search",
          "page_size": 1,
          "max_highlight_length": 0
        }
      }
    }
  ]
}
