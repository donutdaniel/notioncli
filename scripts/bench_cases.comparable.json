{
  "cases": [
    {
      "name": "current-user",
      "cli": ["user", "me"],
      "mcp": {
        "tool": "notion-get-users",
        "arguments": {
          "user_id": "self"
        }
      }
    },
    {
      "name": "list-users-page1",
      "cli": ["user", "list", "--page-size", "1"],
      "mcp": {
        "tool": "notion-get-users",
        "arguments": {
          "page_size": 1
        }
      }
    },
    {
      "name": "search-page",
      "cli": ["search", "$SEARCH_QUERY", "--type", "page", "--limit", "1"],
      "mcp": {
        "tool": "notion-search",
        "arguments": {
          "query": "$SEARCH_QUERY",
          "query_type": "internal",
          "content_search_mode": "workspace_search",
          "page_size": 1,
          "max_highlight_length": 0
        }
      }
    },
    {
      "name": "fetch-page",
      "cli": ["page", "get", "$CONTENT_PAGE_ID"],
      "mcp": {
        "tool": "notion-fetch",
        "arguments": {
          "id": "$CONTENT_PAGE_ID"
        }
      }
    },
    {
      "name": "fetch-database",
      "cli": ["database", "get", "$DATABASE_ID"],
      "mcp": {
        "tool": "notion-fetch",
        "arguments": {
          "id": "$DATABASE_ID"
        }
      }
    },
    {
      "name": "fetch-data-source",
      "cli": ["data-source", "get", "$DATA_SOURCE_ID"],
      "mcp": {
        "tool": "notion-fetch",
        "arguments": {
          "id": "collection://$DATA_SOURCE_ID"
        }
      }
    },
    {
      "name": "create-page-under-page",
      "cli": [
        "page",
        "create",
        "--parent-page",
        "$CONTAINER_PAGE_ID",
        "--title",
        "bench page $BENCH_NONCE"
      ],
      "mcp": {
        "tool": "notion-create-pages",
        "arguments": {
          "parent": {
            "page_id": "$CONTAINER_PAGE_ID"
          },
          "pages": [
            {
              "properties": {
                "title": "bench page $BENCH_NONCE"
              }
            }
          ]
        }
      }
    },
    {
      "name": "update-page-title",
      "cli": [
        "page",
        "update",
        "$CONTENT_PAGE_ID",
        "--body-json",
        "{\"properties\":{\"title\":[{\"type\":\"text\",\"text\":{\"content\":\"bench updated $BENCH_NONCE\"}}]}}"
      ],
      "mcp": {
        "tool": "notion-update-page",
        "arguments": {
          "page_id": "$CONTENT_PAGE_ID",
          "command": "update_properties",
          "properties": {
            "title": "bench updated $BENCH_NONCE"
          }
        }
      }
    },
    {
      "name": "create-row-under-data-source",
      "cli": [
        "page",
        "create",
        "--parent-data-source",
        "$DATA_SOURCE_ID",
        "--title",
        "bench row $BENCH_NONCE"
      ],
      "mcp": {
        "tool": "notion-create-pages",
        "arguments": {
          "parent": {
            "data_source_id": "$DATA_SOURCE_ID"
          },
          "pages": [
            {
              "properties": {
                "Name": "bench row $BENCH_NONCE"
              }
            }
          ]
        }
      }
    },
    {
      "name": "create-comment",
      "cli": [
        "comment",
        "create",
        "--body-json",
        "{\"parent\":{\"page_id\":\"$CONTENT_PAGE_ID\"},\"rich_text\":[{\"type\":\"text\",\"text\":{\"content\":\"bench comment $BENCH_NONCE\"}}]}"
      ],
      "mcp": {
        "tool": "notion-create-comment",
        "arguments": {
          "page_id": "$CONTENT_PAGE_ID",
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "bench comment $BENCH_NONCE"
              }
            }
          ]
        }
      }
    },
    {
      "name": "list-comments",
      "cli": ["comment", "list", "$CONTENT_PAGE_ID"],
      "mcp": {
        "tool": "notion-get-comments",
        "arguments": {
          "page_id": "$CONTENT_PAGE_ID"
        }
      }
    },
    {
      "name": "create-database",
      "cli": [
        "database",
        "create",
        "--body-json",
        "{\"parent\":{\"type\":\"page_id\",\"page_id\":\"$CONTAINER_PAGE_ID\"},\"title\":[{\"type\":\"text\",\"text\":{\"content\":\"bench database $BENCH_NONCE\"}}],\"initial_data_source\":{\"title\":[{\"type\":\"text\",\"text\":{\"content\":\"Primary\"}}],\"properties\":{\"Name\":{\"title\":{}},\"Notes\":{\"rich_text\":{}}}}}"
      ],
      "mcp": {
        "tool": "notion-create-database",
        "arguments": {
          "parent": {
            "page_id": "$CONTAINER_PAGE_ID"
          },
          "title": "bench database $BENCH_NONCE",
          "schema": "CREATE TABLE (\"Name\" TITLE, \"Notes\" RICH_TEXT)"
        }
      }
    },
    {
      "name": "update-data-source-title",
      "cli": [
        "data-source",
        "update",
        "$DATA_SOURCE_ID",
        "--body-json",
        "{\"title\":[{\"type\":\"text\",\"text\":{\"content\":\"bench data source $BENCH_NONCE\"}}]}"
      ],
      "mcp": {
        "tool": "notion-update-data-source",
        "arguments": {
          "data_source_id": "$DATA_SOURCE_ID",
          "title": "bench data source $BENCH_NONCE"
        }
      }
    }
  ]
}
